  "panels": [
    {
      "title": "Not Found Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(ledger_transactions_not_found_total[5m])) / sum(rate(ledger_transactions_found_total[5m]) + rate(ledger_transactions_not_found_total[5m]))" }],
