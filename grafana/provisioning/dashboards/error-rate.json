{
  "uid": "error-rate",
  "title": "Error Rate & Snowflake Bug Detector",
  "tags": ["demo", "flowmap", "snowflake-bug"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Not Found Rate (last 1m)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ledger_transactions_not_found_total[1m]) * 60",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "ops"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Order Errors (total)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "order_errors_total",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Success Rate (Found / Total)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(ledger_transactions_found_total[5m])) / (sum(rate(ledger_transactions_found_total[5m])) + sum(rate(ledger_transactions_not_found_total[5m])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "404 vs 200 (rate per minute)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ledger_transactions_not_found_total[1m]) * 60",
          "refId": "A",
          "legendFormat": "404 (not found - BUG)"
        },
        {
          "expr": "rate(ledger_transactions_found_total[1m]) * 60",
          "refId": "B",
          "legendFormat": "200 (found)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "404 (not found - BUG)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "200 (found)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }
      }
    },
    {
      "id": 5,
      "type": "alertlist",
      "title": "Alerts (if any)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
      "options": {
        "showOptions": "current",
        "maxItems": 10,
        "sortOrder": 1,
        "dashboardAlerts": false
      }
    }
  ]
}
